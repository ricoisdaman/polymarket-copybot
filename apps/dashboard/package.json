{
  "name": "@copybot/dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File ../../scripts/dev-dashboard.ps1",
    "dev:raw": "cross-env NEXT_DIST_TARGET=dev next dev -p 3000",
    "build": "cross-env NEXT_DIST_TARGET=build next build",
    "start": "cross-env NEXT_DIST_TARGET=start next start -p 3000",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"No linter configured\""
  },
  "dependencies": {
    "bootstrap": "^5.3.3",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "cross-env": "^7.0.3"
  }
}
