{
  "name": "copybot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @copybot/db db:generate",
    "db:push": "pnpm --filter @copybot/db exec prisma db push",
    "soak:overnight": "node ./scripts/run-overnight.mjs --hours 8 --poll-seconds 30"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.8.0"
  }
}
